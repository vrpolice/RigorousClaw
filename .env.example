# LLM APIs
OPENAI_API_KEY=your_openai_api_key_here
# If you are using a custom endpoint (e.g. proxy, DeepSeek, SiliconFlow):
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat

# Skill APIs
TAVILY_API_KEY=your_tavily_api_key_here
JINA_API_KEY=your_jina_api_key_here

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Vector DB (Qdrant)
# By default, the app uses a local file-based Qdrant database (no API key required).
# If you want to use Qdrant Cloud, set these:
# QDRANT_URL=your_qdrant_cloud_url
# QDRANT_API_KEY=your_qdrant_api_key

# Crawl4AI Configuration (Optional, depending on advanced setups)
# CRAWL4AI_API_TOKEN=your_crawl4ai_api_token
